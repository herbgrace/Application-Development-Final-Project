@page "/allmovies"
@inject TmdbService TmdbService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@using MovieTracker.Controllers


<h1>Discover Movies</h1>

<div class="filters">
    <div class="search-box">
        <input @bind="_searchTerm"
               @onkeyup="HandleKeyUp"
               placeholder="Search for a movie..."
               class="search-input" />
        <button @onclick="ApplyFilters" class="btn-search">Search</button>
    </div>

     <label>Genre:</label>
    <select @bind="_selectedGenre">
        <option value="28">Action</option>
        <option value="12">Adventure</option>
        <option value="16">Animation</option>
        <option value="35">Comedy</option>
        <option value="80">Crime</option>
        <option value="99">Documentary</option>
        <option value="18">Drama</option>
        <option value="10751">Family</option>
        <option value="14">Fantasy</option>
        <option value="36">History</option>
        <option value="27">Horror</option>
        <option value="10402">Music</option>
        <option value="9648">Mystery</option>
        <option value="10749">Romance</option>
        <option value="878">Science Fiction</option>
        <option value="10770">TV Film</option>
        <option value="53">Thriller</option>
        <option value="10752">War</option>
        <option value="37">Western</option>
    </select>  

    <label>Sort By:</label>
    <select @bind="_selectedSort"> 
        <option value="popularity.desc">Most Popular</option>
        <option value="release_date.desc">Most Recent</option>
        <option value="vote_average.desc">Highest Rated</option>
    </select>


    <button @onclick="ApplyFilters">Apply Filters</button>
</div>


@if (movies == null)
{
    <p>Loading movies...</p>
}
else
{
    <div class="movie-grid">
        @foreach (var movie in movies)
        {

            <div class="movie-card" @onclick="() => NavigateToDetails(movie.Id)" style="cursor: pointer;">
                <div class="poster-container">
                    @if (!string.IsNullOrEmpty(movie.Poster_Path))
                    {
                        <img src="https://image.tmdb.org/t/p/w500/@movie.Poster_Path" alt="@movie.Title" />
                    }
                    else
                    {
                        <div class="no-image">No Poster</div>
                    }
                </div>
                <div class="movie-card-body">
                    <h3>@movie.Title</h3>
                    <p>@movie.Overview</p>
                  
                    <button class="btn-add"
                            @onclick:stopPropagation="true"
                            @onclick="() => AddToWatchlist(movie)">
                        + Watchlist
                    </button>
                </div>
            </div>
        }
</div>

    <div class="pagination">
        <button @onclick="PreviousPage" disabled="@(_currentPage == 1)">Previous</button>
        <span>Page @_currentPage of @_totalPages</span>
        <button @onclick="NextPage" disabled="@(_currentPage == _totalPages)">Next</button>
    </div>
  


    @code {
    private List<Movie> movies;
    private string _searchTerm = "";
    private string _selectedGenre = "";
    private string _selectedSort = "popularity.desc";
    private int _currentPage = 1;
    private int _totalPages = 1;
    private bool _isLoading = false; 

    protected override async Task OnInitializedAsync()
    {
        await LoadMovies(_currentPage);
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ApplyFilters();
    }

    private async Task LoadMovies(int page = 1)
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            MovieResponse response;

            if (!string.IsNullOrWhiteSpace(_searchTerm))
            {
                response = await TmdbService.SearchMovies(_searchTerm, page);
            }
            else
            {
                response = await TmdbService.GetMovies(genreIds: _selectedGenre, sortBy: _selectedSort, page: page);
            }

            movies = response?.Results ?? new List<Movie>();
            _currentPage = response?.Page ?? 1;
            _totalPages = response?.Total_Pages ?? 1;
        } 
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
        }
    }

    private async Task ApplyFilters()
    {
        _currentPage = 1;
        await LoadMovies(_currentPage);
    }

    private async Task NextPage() => await LoadMovies(_currentPage + 1);
    private async Task PreviousPage() => await LoadMovies(_currentPage - 1);
    private void NavigateToDetails(int movieId)
    {
        NavigationManager.NavigateTo($"/moviedetails/{movieId}");
    }

    void AddToWatchlist(Movie movie)
    {
        if (!WatchlistController.movies.Any(m => m.Title == movie.Title))
        {
            WatchlistController.movies.Add(movie);
        }
    }
}}